# Environment Configuration for AQI Dashboard Backend

# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Atlas Connection
# Get your connection string from: https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/aqi-dashboard?retryWrites=true&w=majority

# WAQI API Configuration
# Get your API key from: https://aqicn.org/data-platform/token/
WAQI_API_KEY=e52b20dc479791e02b4673f662efb54a4c72d08e

# API Configuration
OPEN_METEO_BASE_URL=https://air-quality-api.open-meteo.com/v1
WAQI_BASE_URL=https://api.waqi.info

# Cron Job Configuration (default: cities to monitor)
DEFAULT_CITIES=New York,London,Beijing,Delhi,Tokyo,Mumbai,Los Angeles,Paris,Sydney,São Paulo

# Cache Configuration (in seconds)
CACHE_TTL=300

# Prediction Configuration
PREDICTION_DAYS=30
MIN_HISTORICAL_DAYS=15
